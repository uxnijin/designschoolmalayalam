rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User progress data — only accessible by the authenticated owner
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Jobs board — publicly readable, only writable by authenticated users
    // (You manage jobs directly via the Firestore console)
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
